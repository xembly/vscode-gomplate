{
  "name": "gomplate",
  "displayName": "gomplate template renderer",
  "description": "Language support for go text/template",
  "version": "1.0.0",
  "publisher": "xembly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xembly/vscode-gomplate"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [ "Programming Languages" ],
  "keywords": [
    "gomplate",
    "go",
    "file",
    "template",
    "tmpl",
    "snippet"
  ],
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "vscode-tmgrammar-test": "^0.1.3"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:snap",
    "test:unit": "vscode-tmgrammar-test 'tests/unit/*.tmpl'",
    "test:snap": "vscode-tmgrammar-snap 'tests/fixtures/**/*.tmpl'",
    "test:snap:update": "vscode-tmgrammar-snap --updateSnapshot 'tests/fixtures/**/*.tmpl'",
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish"
  },
  "contributes": {
    "languages": [
      {
        "id": "gots",
        "aliases": [
          "Golang TypeScript Template",
          "gots"
        ],
        "extensions": [
          ".gots",
          ".ts.tmpl",
          ".ts.tpl",
          ".ts.gotmpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "gojs",
        "aliases": [
          "Golang JavaScript Template",
          "gojs"
        ],
        "extensions": [
          ".gojs",
          ".js.tmpl",
          ".js.tpl",
          ".js.gotmpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "goR",
        "aliases": [
          "Golang R Template",
          "goR"
        ],
        "extensions": [
          ".goR",
          ".R.tmpl",
          ".R.tpl",
          ".R.gotmpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "godockerfile",
        "aliases": [
          "Golang Dockerfile Template",
          "godockerfile"
        ],
        "extensions": [
          ".godockerfile",
          ".Dockerfile.tmpl",
          ".Dockerfile.tpl",
          ".Dockerfile.gotmpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "goshell",
        "aliases": [
          "Golang Shell Template",
          "goshell",
          "goshellscript"
        ],
        "extensions": [
          ".gosh"
        ],
        "filenamePatterns": [
          "**/*.{sh,bash,fish,zsh}.{tpl,tmpl,gotmpl}",
          "**/{.,dot_}bash{_login,_logout,_profile,rc}.{tpl,tmpl,gotmpl}",
          "**/{.,dot_}z{login,logout,profile,shenv,shrc}.{tpl,tmpl,gotmpl}",
          "**/config.fish.{tpl,tmpl,gotmpl}"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "gophp",
        "aliases": [
          "Golang PHP Template",
          "gophp"
        ],
        "extensions": [
          ".gophp",
          ".php.tmpl",
          ".php.tpl",
          ".php.gotmpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "gojava",
        "aliases": [
          "Golang Java Template",
          "gojava"
        ],
        "extensions": [
          ".gojava",
          ".java.tmpl",
          ".java.tpl",
          ".java.gotmpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "gogo",
        "aliases": [
          "Golang GO Template",
          "gogo"
        ],
        "extensions": [
          ".gogo",
          ".go.tmpl",
          ".go.tpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "gomplate",
        "aliases": [
          "Golang Text Template",
          "gomplate"
        ],
        "extensions": [
          ".gotmpl",
          ".tmpl",
          ".tpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "gohtml",
        "aliases": [
          "Golang HTML Template",
          "gohtml"
        ],
        "extensions": [
          ".html",
          ".gohtml",
          ".html.tmpl",
          ".html.tpl",
          ".html.gotmpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "goyaml",
        "aliases": [
          "Golang YAML Template",
          "goyaml"
        ],
        "extensions": [
          ".yml.tpl",
          ".yaml.tpl",
          ".yml.tmpl",
          ".yaml.tmpl",
          ".yaml.gotmpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "gojson",
        "aliases": [
          "Golang JSON Template",
          "gojson"
        ],
        "extensions": [
          ".json.tpl",
          ".json.tmpl",
          ".json.gotmpl"
        ],
        "configuration": "./gomplate.configuration.json"
      },
      {
        "id": "gocss",
        "aliases": [
          "Golang css Template",
          "gocss"
        ],
        "extensions": [
          ".css",
          ".gocss",
          ".css.tmpl",
          ".css.tpl"
        ],
        "configuration": "./gomplate.configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gots",
        "scopeName": "source.gots",
        "path": "./syntaxes/gots.tmLanguage"
      },
      {
        "language": "gojs",
        "scopeName": "source.gojs",
        "path": "./syntaxes/gojs.tmLanguage"
      },
      {
        "language": "godockerfile",
        "scopeName": "source.godockerfile",
        "path": "./syntaxes/godockerfile.tmLanguage"
      },
      {
        "language": "goshell",
        "scopeName": "source.goshell",
        "path": "./syntaxes/goshell.tmLanguage"
      },
      {
        "language": "goR",
        "scopeName": "source.goR",
        "path": "./syntaxes/goR.tmLanguage"
      },
      {
        "language": "gophp",
        "scopeName": "source.gophp",
        "path": "./syntaxes/gophp.tmLanguage"
      },
      {
        "language": "gojava",
        "scopeName": "source.gojava",
        "path": "./syntaxes/gojava.tmLanguage"
      },
      {
        "language": "gogo",
        "scopeName": "source.gogo",
        "path": "./syntaxes/gogo.tmLanguage"
      },
      {
        "language": "gomplate",
        "scopeName": "source.gomplate",
        "path": "./syntaxes/gomplate.tmLanguage"
      },
      {
        "language": "gohtml",
        "scopeName": "source.gohtml",
        "path": "./syntaxes/gohtml.tmLanguage"
      },
      {
        "language": "goyaml",
        "scopeName": "source.goyaml",
        "path": "./syntaxes/goyaml.tmLanguage"
      },
      {
        "scopeName": "gomplate.injection",
        "path": "./syntaxes/gomplate-injection.tmLanguage.json",
        "injectTo": [
          "source.yaml",
          "source.goyaml",
          "text.html.basic",
          "source.gohtml",
          "source.js",
          "source.gojs",
          "source.ts",
          "source.gots",
          "source.json",
          "source.gojson",
          "source.css",
          "source.gocss",
          "source.shell",
          "source.goshell",
          "source.php",
          "source.gophp",
          "source.java",
          "source.gojava",
          "source.go",
          "source.gogo",
          "source.dockerfile",
          "source.godockerfile",
          "source.r",
          "source.goR"
        ]
      },
      {
        "language": "gojson",
        "scopeName": "source.gojson",
        "path": "./syntaxes/gojson.tmLanguage"
      },
      {
        "language": "gocss",
        "scopeName": "source.gocss",
        "path": "./syntaxes/gocss.tmLanguage"
      }
    ]
  }
}
